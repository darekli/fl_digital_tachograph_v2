# Example Gradle properties for this project
# Copy values as needed into android/gradle.properties on your machine.

org.gradle.jvmargs=-Xmx8G -XX:MaxMetaspaceSize=4G -XX:ReservedCodeCacheSize=512m -XX:+HeapDumpOnOutOfMemoryError
# Use your local Android Studio JBR/JDK path.
org.gradle.java.home=/Users/your-user/Applications/Android Studio.app/Contents/jbr/Contents/Home
android.useAndroidX=true
android.enableJetifier=true

